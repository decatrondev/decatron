{
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Database=decatron_prod;Username=decatron_user;Password=YOUR_DATABASE_PASSWORD_HERE"
    },
    "TwitchSettings": {
        "ClientId": "YOUR_TWITCH_CLIENT_ID_HERE",
        "ClientSecret": "YOUR_TWITCH_CLIENT_SECRET_HERE",
        "BotUsername": "your_bot_username_here",
        "ChannelId": "YOUR_CHANNEL_ID_HERE",
        "RedirectUri": "http://localhost:7264/api/auth/callback",
        "WebhookSecret": "YOUR_WEBHOOK_SECRET_HERE",
        "EventSubWebhookSecret": "YOUR_EVENTSUB_SECRET_HERE",
        "FrontendUrl": "http://localhost:5173"
    },
    "JwtSettings": {
        "SecretKey": "YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG_HERE",
        "ExpiryMinutes": 60,
        "RefreshTokenExpiryDays": 7
    }
}
